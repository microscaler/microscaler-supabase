# Copy to application.secrets.env and fill (or copy from PriceWhisperer and SOPS-decrypt).
# Required keys for Supabase stack:
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# POSTGRES_META_DB_PASSWORD=postgres
# POSTGRES_META_DB_PASSWORD_ENCRYPTION_KEY=<32-byte-key>
# PGRST_DB_URI=postgres://authenticator:postgres@postgres:5432/postgres
# PGRST_JWT_SECRET=<jwt-secret>
# PGRST_APP_SETTINGS_JWT_SECRET=<jwt-secret>
# REALTIME_DB_PASSWORD=postgres
# REALTIME_JWT_SECRET=<jwt-secret>
# REALTIME_SECRET_KEY_BASE=<base64-key>
# SUPERVISOR_DATABASE_URL=postgres://...
# SUPERVISOR_SECRET_KEY_BASE=<base64-key>
# GOTRUE_DB_PASSWORD=postgres
# GOTRUE_DATABASE_URL=postgres://...
# GOTRUE_JWT_SECRET=<jwt-secret>
# STORAGE_API_* (JWT, DB, S3 if using MinIO)
# STUDIO_* (DB, JWT, encryption)
# EDGE_RUNTIME_* (JWT, DB)
#
# shared-kind-cluster platform-data (pact-postgres, pact-broker, minio) — required if those manifests are applied:
# PACT_POSTGRES_PASSWORD=<password>
# PACT_BROKER_DATABASE_URL=postgres://pact:<password>@pact-postgres.data.svc.cluster.local:5432/pact
# PACT_BROKER_BASIC_AUTH_USERNAME=pact
# PACT_BROKER_BASIC_AUTH_PASSWORD=<password>
# MINIO_ROOT_USER=minio
# MINIO_ROOT_PASSWORD=<password>
#
# Mailpit / Inbucket / imgproxy use infra-config only (see application.properties), not infra-secrets.
